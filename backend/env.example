# Pripojenie k PostgreSQL databáze (connection string)
# Príklad: postgres://user:password@localhost:5432/bozp
DATABASE_URL=

# Tajný kľúč pre podpisovanie a overovanie JWT tokenov
# Použite náhodný dlhý reťazec (napr. vygenerovaný cez: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# URL adresa frontendu – povolená pre CORS
# Príklad lokálne: http://localhost:5173
# Príklad produkcia: https://moja-aplikacia.onrender.com
FRONTEND_URL=

# Storage na ukladanie obrázkov, môže byť nahradený aj iným poskytovateľom
# Cloudinary – názov vášho cloudu (nájdete v Cloudinary dashboarde pod "Cloud name")
CLOUDINARY_CLOUD_NAME=

# Cloudinary – API kľúč (nájdete v Cloudinary dashboarde pod "API Keys")
CLOUDINARY_API_KEY=

# Cloudinary – API tajný kľúč (nájdete v Cloudinary dashboarde pod "API Keys")
CLOUDINARY_API_SECRET=
